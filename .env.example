# Rivendell AI DJ — Environment Variables
#
# Copy to .env and adjust, or set as environment variables.

# ═══════════════════════════════════════════════════════════════════════════
# REQUIRED: Rivendell RDXport connection
# ═══════════════════════════════════════════════════════════════════════════
# URL of your Rivendell Apache server (where /rd-bin/ is served)
RIVENDELL_URL=http://localhost

# Rivendell user credentials (create a user in RDAdmin with API access)
RIVENDELL_USER=user
RIVENDELL_PASS=your_password_here

# Active log name to monitor for transitions (e.g. "2026-07-07/Morning")
# Optional — if not set, only uses /rd-bin/rdnowplaying polling
RIVENDELL_LOG=

# Rivendell group where AI DJ voice tracks will be imported
# Create this group in RDAdmin → Manage Groups → Add (name: AI_DJ)
RIVENDELL_AI_GROUP=AI_DJ

# ═══════════════════════════════════════════════════════════════════════════
# REQUIRED: LLM API (any OpenAI-compatible)
# ═══════════════════════════════════════════════════════════════════════════
# Free option: OpenRouter (https://openrouter.ai) — 24 free models, no card
OPENAI_API_KEY=sk-or-v1-...
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free

# Other free options:
#   Groq: https://console.groq.com → OPENAI_BASE_URL=https://api.groq.com/openai/v1, OPENAI_MODEL=llama-3.3-70b-versatile
#   Cerebras: https://cerebras.ai → OPENAI_BASE_URL=https://api.cerebras.ai/v1

# ═══════════════════════════════════════════════════════════════════════════
# REQUIRED: TTS engine (pick one)
# ═══════════════════════════════════════════════════════════════════════════
# Option A: Piper (local, free, fast — RECOMMENDED)
# Install: https://github.com/rhasspy/piper
TTS_ENGINE=piper
TTS_VOICE=en_GB-alan-medium
PIPER_PATH=/usr/local/bin/piper
PIPER_VOICES_DIR=/opt/piper/voices

# Option B: OpenAI TTS (cloud, $0.015/min, highest quality)
# TTS_ENGINE=openai
# OPENAI_TTS_API_KEY=sk-...
# OPENAI_TTS_VOICE=alloy

# Option C: ElevenLabs (cloud, $0.30/1k chars, best voice cloning)
# TTS_ENGINE=elevenlabs
# ELEVENLABS_API_KEY=...
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL: DJ persona customization
# ═══════════════════════════════════════════════════════════════════════════
DJ_NAME=ECHO
DJ_STYLE=laid-back late-night DJ
# Override the full system prompt (otherwise built from DJ_NAME + DJ_STYLE)
# DJ_SYSTEM_PROMPT=You are ECHO, a...

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL: Polling behavior
# ═══════════════════════════════════════════════════════════════════════════
# How often to poll Rivendell for now-playing changes (seconds)
POLL_INTERVAL_SEC=5

# Minimum gap between AI DJ inserts (seconds) — prevents spamming during rapid transitions
MIN_TRANSITION_GAP_SEC=30
