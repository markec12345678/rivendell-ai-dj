# Rivendell AI DJ — Environment Variables
#
# Copy to .env and adjust, or set as environment variables.
# For Render: set these in Render dashboard → Environment.

# ═══════════════════════════════════════════════════════════════════════════
# MODE SELECTION
# ═══════════════════════════════════════════════════════════════════════════
# DEMO_MODE=true  → simulate Rivendell (no real Rivendell needed, has web dashboard)
# DEMO_MODE=false → connect to real Rivendell via RDXport API
#
# Default: true if RIVENDELL_PASS is not set, false otherwise (auto-detected)
DEMO_MODE=true

# HTTP port for demo dashboard (Render auto-injects PORT)
PORT=7701

# Demo mode: how often to simulate track transitions (seconds)
TRANSITION_INTERVAL_SEC=45

# ═══════════════════════════════════════════════════════════════════════════
# REQUIRED: LLM API (multi-provider chain with auto-fallback)
# ═══════════════════════════════════════════════════════════════════════════
# Provider chain (tried in order until one succeeds):
#   1. Primary:    OPENAI_API_KEY + OPENAI_MODEL
#   2. Secondary:  OPENAI_API_KEY + OPENAI_MODEL_FALLBACK (same key, different model)
#   3. Tertiary:   GROQ_API_KEY (if set)
#   4. Static fallback (always works: "Coming up next, {title}.")

# --- Primary (best quality, paid) ---
# OpenRouter with GLM-5.2 (best DJ intros, ~$0.0009/1k tokens)
# Get key: https://openrouter.ai (add $5 credits to use paid models)
OPENAI_API_KEY=sk-or-v1-...
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=z-ai/glm-5.2

# --- Secondary (free fallback on same OpenRouter key) ---
OPENAI_MODEL_FALLBACK=nvidia/nemotron-3-ultra-550b-a55b:free

# --- Tertiary (Groq — RECOMMENDED free option, no credit card) ---
# Get key: https://console.groq.com (30 req/min, 14k req/day free)
# This kicks in when OpenRouter rate-limits or runs out of credits.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL: Real Rivendell connection (only if DEMO_MODE=false)
# ═══════════════════════════════════════════════════════════════════════════
# URL of your Rivendell Apache server (where /rd-bin/ is served)
# RIVENDELL_URL=http://localhost

# Rivendell user credentials (create a user in RDAdmin with API access)
# RIVENDELL_USER=user
# RIVENDELL_PASS=your_password_here

# Active log name to monitor for transitions (e.g. "2026-07-07/Morning")
# RIVENDELL_LOG=

# Rivendell group where AI DJ voice tracks will be imported
# RIVENDELL_AI_GROUP=AI_DJ

# Polling interval for real Rivendell (seconds)
# POLL_INTERVAL_SEC=5

# Minimum gap between AI DJ inserts (seconds)
# MIN_TRANSITION_GAP_SEC=30

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL: DJ persona customization
# ═══════════════════════════════════════════════════════════════════════════
DJ_NAME=ECHO
DJ_STYLE=laid-back late-night DJ
# Override the full system prompt (otherwise built from DJ_NAME + DJ_STYLE)
# DJ_SYSTEM_PROMPT=You are ECHO, a...

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL: TTS engine (demo mode uses browser-side Web Speech API by default)
# ═══════════════════════════════════════════════════════════════════════════
# TTS_ENGINE=browser  (default — free, uses browser's Web Speech API)
# TTS_ENGINE=piper    (local, free — needs Piper installed)
# TTS_ENGINE=openai   (cloud, $0.015/min — needs OPENAI_TTS_API_KEY)
# TTS_ENGINE=elevenlabs (cloud, voice cloning — needs ELEVENLABS_API_KEY)
TTS_ENGINE=browser

# Piper TTS config (only if TTS_ENGINE=piper)
# TTS_VOICE=en_GB-alan-medium
# PIPER_PATH=/usr/local/bin/piper
# PIPER_VOICES_DIR=/opt/piper/voices
